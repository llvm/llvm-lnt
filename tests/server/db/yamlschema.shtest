# RUN: rm -rf "%t.install"
# RUN: %{utils}/with_postgres.sh %t.pg.log \
# RUN:     bash %s %s "%t.install" %{src_root} %S
set -eu

THIS_FILE="$1"
INSTALL="$2"
SRC_ROOT="$3"
TEST_SRC_DIR="$4"

lnt create "${INSTALL}" --db-dir ${LNT_TEST_DB_URI} --default-db ${LNT_TEST_DB_NAME}
ln -sf "${SRC_ROOT}/docs/my_suite.yaml" "${INSTALL}/schemas/"

lnt import "${INSTALL}" -s my_suite "${TEST_SRC_DIR}/Inputs/customschema-report.json" \
    2>&1 | filecheck "${THIS_FILE}"

# CHECK: Import succeeded.
# CHECK: Imported Data
# CHECK-NEXT: -------------
# CHECK-NEXT: Added Machines: 1
# CHECK-NEXT: Added Runs    : 1
# CHECK-NEXT: Added Tests   : 1
#
# CHECK: Results
# CHECK: ----------------
# CHECK: PASS : 3


# Migration Tests
# ===============
#
# Inserting with an extra field shouldn't work just yet
! lnt import "${INSTALL}" -s my_suite "${TEST_SRC_DIR}/Inputs/customschema-report2.json" \
    2>&1 | filecheck --check-prefix=NOTUPGRADED "${THIS_FILE}"
# NOTUPGRADED: Metric 'newfield' unknown in suite

# Upgrading to a schema with metrics/fields removed should fail
rm -f "${INSTALL}/schemas/my_suite.yaml"
ln -sf "${TEST_SRC_DIR}/Inputs/schema-example-nomigration0.yaml" "${INSTALL}/schemas/my_suite.yaml"
! lnt import "${INSTALL}" -s my_suite "${TEST_SRC_DIR}/Inputs/customschema-report.json" \
    2>&1 | filecheck --check-prefix=NOMIGRATION0 "${THIS_FILE}"
# NOMIGRATION0: Cannot automatically migrate database: Metrics removed: data_size

rm -f "${INSTALL}/schemas/my_suite.yaml"
ln -sf "${TEST_SRC_DIR}/Inputs/schema-example-nomigration1.yaml" "${INSTALL}/schemas/my_suite.yaml"
! lnt import "${INSTALL}" -s my_suite "${TEST_SRC_DIR}/Inputs/customschema-report.json" \
    2>&1 | filecheck --check-prefix=NOMIGRATION1 "${THIS_FILE}"
# NOMIGRATION1: Cannot automatically migrate database: Machine fields removed: os

rm -f "${INSTALL}/schemas/my_suite.yaml"
ln -sf "${TEST_SRC_DIR}/Inputs/schema-example-nomigration2.yaml" "${INSTALL}/schemas/my_suite.yaml"
! lnt import "${INSTALL}" -s my_suite "${TEST_SRC_DIR}/Inputs/customschema-report.json" \
    2>&1 | filecheck --check-prefix=NOMIGRATION2 "${THIS_FILE}"
# NOMIGRATION2: Cannot automatically migrate database: Type mismatch in metric 'data_size'


# This upgrade should finally work
rm -f "${INSTALL}/schemas/my_suite.yaml"
ln -sf "${TEST_SRC_DIR}/Inputs/schema-example-migratable.yaml" "${INSTALL}/schemas/my_suite.yaml"
lnt import "${INSTALL}" "${TEST_SRC_DIR}/Inputs/customschema-report2.json" -s my_suite --show-sql \
    2>&1 | filecheck --check-prefix=MIGRATION "${THIS_FILE}"
#
# MIGRATION: ALTER TABLE "my_suite_Sample" ADD COLUMN newfield {{FLOAT|DOUBLE PRECISION}}
# MIGRATION: ALTER TABLE "my_suite_Run" ADD COLUMN new_run_field VARCHAR(256)
# MIGRATION: ALTER TABLE "my_suite_Machine" ADD COLUMN new_machine_field VARCHAR(256)
#
# MIGRATION: Import succeeded.
# MIGRATION: Imported Data
# MIGRATION-NEXT: -------------
# MIGRATION-NEXT: Added Runs    : 1
#
# MIGRATION: Results
# MIGRATION: PASS : 4
